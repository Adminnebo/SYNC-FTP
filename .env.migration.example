# Copy to .env.migration and fill in real values for LOCAL runs.
# In GitHub Actions these come from repo Secrets instead (see README).

# --- FTP ---
FTP_HOST=win8085.site4now.net
FTP_PORT=21
FTP_USER=your-ftp-user
FTP_PASSWORD=your-ftp-password
# Root path to walk on the FTP. Leave as / to scan everything.
FTP_BASE_PATH=/

# --- Supabase (FTP) — for migrate.js / `npm run sync` ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=your-ftp-bucket-name

# --- Google Drive (public folder) — for `npm run sync-drive` ---
# API key from Google Cloud (Drive API enabled). Folder must be public
# ("anyone with the link"). FOLDER_ID is the long id in the folder URL:
# https://drive.google.com/drive/folders/<DRIVE_FOLDER_ID>
GOOGLE_API_KEY=your-google-api-key
DRIVE_FOLDER_ID=your-drive-folder-id
# Drive uses its OWN Supabase project (different from the FTP one above).
# NOTE: drive-sync.js reads SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY /
# SUPABASE_BUCKET. To run it locally, temporarily set those three to the
# Drive project's values. In CI the workflow maps the DRIVE_* secrets below
# onto those names, so no conflict there.
DRIVE_SUPABASE_URL=https://yyyyyyyyyyyy.supabase.co
DRIVE_SUPABASE_SERVICE_ROLE_KEY=your-drive-project-service-role-key
DRIVE_SUPABASE_BUCKET=Lucas_fichas_tecnicas
